<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.1.0</version>
        <relativePath/> <!-- lookup parent from repository -->
    </parent>

    <groupId>dev.engnotes</groupId>
    <artifactId>financial-intelligence-platform</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>financial-intelligence-platform</name>
    <description>Serverless financial intelligence platform (parent aggregator)</description>

    <modules>
        <module>integration-test-support</module>
        <module>functions/ingestion-function</module>
        <module>functions/insight-function</module>
        <module>functions/query-function</module>
        <module>functions/watchlist-function</module>
        <module>functions/authorizer-function</module>
        <module>functions/consent-function</module>
        <module>functions/dsr-function</module>
        <module>functions/notifier-function</module>
        <module>infrastructure</module>
    </modules>

    <properties>
        <java.version>25</java.version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Spring Cloud (release train aligned to Spring Boot 4.1.x; it manages
             spring-cloud-function + the AWS adapter - do not pin those yourself) -->
        <spring-cloud.version>2025.1.2</spring-cloud.version>

        <!-- Override Boot's default (2.x) so integration-test-support can use the stable 1.x
             artifact IDs (localstack, junit-jupiter). Remove when migrating to TC 2.x names. -->
        <testcontainers.version>1.21.4</testcontainers.version>

        <!-- AWS SDK v2 -->
        <aws-sdk.version>2.47.5</aws-sdk.version>
        <aws-lambda-java.version>1.4.0</aws-lambda-java.version>
        <aws-lambda-events.version>3.16.1</aws-lambda-events.version>
        <java-jwt.version>4.5.2</java-jwt.version>
        <jwks-rsa.version>0.24.1</jwks-rsa.version>

        <!-- JaCoCo 0.8.15: first line with official Java 25 (bytecode 69) support is 0.8.14. -->
        <jacoco.version>0.8.15</jacoco.version>
        <!-- Coverage gate: every function module must hold >= 80% merged unit+IT line coverage. -->
        <jacoco.check.haltOnFailure>true</jacoco.check.haltOnFailure>
        <!-- Populated by the JaCoCo agents only under -Pintegration-tests; empty otherwise so the
             plain build runs uninstrumented. -->
        <jacocoUnitAgent></jacocoUnitAgent>
        <jacocoItAgent></jacocoItAgent>
    </properties>

    <!--
      This is a pure parent/aggregator POM: it declares NO concrete dependencies so that
      each module (Lambda functions, CDK app) only pulls what it actually needs. It provides
      shared dependency/version management and the Java version to every module.
    -->
    <dependencyManagement>
        <dependencies>
            <!-- Boot's own dependency management comes from the spring-boot-starter-parent
                 parent above; no spring-boot-dependencies import needed here. -->
            <dependency>
                <groupId>org.springframework.cloud</groupId>
                <artifactId>spring-cloud-dependencies</artifactId>
                <version>${spring-cloud.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <!-- AWS SDK v2 BOM -->
            <dependency>
                <groupId>software.amazon.awssdk</groupId>
                <artifactId>bom</artifactId>
                <version>${aws-sdk.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- Every AWS SDK client is built with UrlConnectionHttpClient (sync); the default
                 Apache (sync) and Netty (async) HTTP clients are unused. Mark them provided so they
                 are dropped from the Lambda uber-JARs (smaller artifact, faster cold start). -->
            <dependency>
                <groupId>software.amazon.awssdk</groupId>
                <artifactId>apache-client</artifactId>
                <version>${aws-sdk.version}</version>
                <scope>provided</scope>
            </dependency>
            <dependency>
                <groupId>software.amazon.awssdk</groupId>
                <artifactId>netty-nio-client</artifactId>
                <version>${aws-sdk.version}</version>
                <scope>provided</scope>
            </dependency>

            <!-- Lambda runtime -->
            <dependency>
                <groupId>com.amazonaws</groupId>
                <artifactId>aws-lambda-java-core</artifactId>
                <version>${aws-lambda-java.version}</version>
            </dependency>
            <dependency>
                <groupId>com.amazonaws</groupId>
                <artifactId>aws-lambda-java-events</artifactId>
                <version>${aws-lambda-events.version}</version>
            </dependency>

            <!-- Tracing: no SDK on purpose. Traces come from managed active tracing
                 (Tracing.ACTIVE in CDK); the X-Ray SDK is deprecated in favour of
                 OpenTelemetry. See docs/adr/0001-tracing-opentelemetry-direction.md. -->

            <!-- JWT verification for the API authorizer -->
            <dependency>
                <groupId>com.auth0</groupId>
                <artifactId>java-jwt</artifactId>
                <version>${java-jwt.version}</version>
            </dependency>
            <dependency>
                <groupId>com.auth0</groupId>
                <artifactId>jwks-rsa</artifactId>
                <version>${jwks-rsa.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <!-- Lambda packaging lives in pluginManagement so only the function modules that declare
             the plugin pick it up; the CDK `infrastructure` module never does.
             The Lambda Java runtime loads the handler
             (org.springframework.cloud.function.adapter.aws.FunctionInvoker) from the classpath
             root, which a Spring Boot fat JAR hides under BOOT-INF/. So functions ship a flat shaded
             uber-JAR instead. A shaded JAR has no Boot Start-Class manifest entry, so each function
             sets MAIN_CLASS (its @SpringBootApplication) in the CDK for FunctionInvoker to find. -->
        <pluginManagement>
            <plugins>
                <!-- Inherits spring-boot-starter-parent's shade transformer config (merges
                     spring.factories, META-INF/services, etc.); we only bind the execution and keep
                     the dependency-reduced pom off. Each function sets <start-class> so the uber-JAR
                     manifest names the @SpringBootApplication. -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-shade-plugin</artifactId>
                    <configuration>
                        <createDependencyReducedPom>false</createDependencyReducedPom>
                        <!-- Quiet benign uber-JAR warnings: drop JPMS descriptors (we run on the
                             classpath, not the module path) and signature files, and merge the
                             duplicated META-INF service/license/notice resources instead of keeping
                             an arbitrary single copy. -->
                        <filters>
                            <filter>
                                <artifact>*:*</artifact>
                                <excludes>
                                    <exclude>module-info.class</exclude>
                                    <exclude>META-INF/versions/*/module-info.class</exclude>
                                    <exclude>META-INF/*.SF</exclude>
                                    <exclude>META-INF/*.DSA</exclude>
                                    <exclude>META-INF/*.RSA</exclude>
                                    <!-- Duplicated license/notice variants the Apache transformers
                                         do not consume, plus IDE/dev-time-only metadata not used by
                                         the Lambda runtime. Runtime autoconfig metadata is kept. -->
                                    <exclude>META-INF/DEPENDENCIES</exclude>
                                    <exclude>META-INF/LICENSE.txt</exclude>
                                    <exclude>META-INF/license.txt</exclude>
                                    <exclude>META-INF/license/**</exclude>
                                    <exclude>META-INF/*-LICENSE</exclude>
                                    <exclude>META-INF/*-LICENSE.txt</exclude>
                                    <exclude>META-INF/NOTICE.txt</exclude>
                                    <exclude>META-INF/notice.txt</exclude>
                                    <exclude>META-INF/spring.tooling</exclude>
                                    <exclude>META-INF/spring-devtools.properties</exclude>
                                    <exclude>META-INF/spring-configuration-metadata.json</exclude>
                                </excludes>
                            </filter>
                        </filters>
                        <transformers>
                            <transformer
                                implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
                            <transformer
                                implementation="org.apache.maven.plugins.shade.resource.ApacheLicenseResourceTransformer"/>
                            <transformer
                                implementation="org.apache.maven.plugins.shade.resource.ApacheNoticeResourceTransformer"/>
                        </transformers>
                    </configuration>
                    <executions>
                        <execution>
                            <phase>package</phase>
                            <goals>
                                <goal>shade</goal>
                            </goals>
                        </execution>
                    </executions>
                </plugin>
                <!-- Surefire: opt in to dynamic agent loading (Mockito/ByteBuddy) so the JVM stops
                     warning that it will be disallowed in a future release, and disable CDS sharing
                     to silence the bootclasspath-append notice. -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <configuration>
                        <!-- @{...} is Surefire late-replacement: the JaCoCo agent property composes
                             here instead of being overwritten (empty outside -Pintegration-tests). -->
                        <argLine>@{jacocoUnitAgent} -XX:+EnableDynamicAgentLoading -Xshare:off</argLine>
                    </configuration>
                </plugin>
                <!-- Failsafe runs *IT integration tests in the integration-test/verify phases.
                     Config only here; executions are bound under the integration-tests profile so
                     a plain `mvn verify` never needs Docker. -->
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-failsafe-plugin</artifactId>
                    <configuration>
                        <argLine>@{jacocoItAgent} -XX:+EnableDynamicAgentLoading -Xshare:off</argLine>
                    </configuration>
                </plugin>
                <!-- JaCoCo merged unit+IT coverage. All executions run only in modules that declare
                     the plugin, and those declarations live inside each function module's
                     integration-tests profile, so the plain build is never instrumented. -->
                <plugin>
                    <groupId>org.jacoco</groupId>
                    <artifactId>jacoco-maven-plugin</artifactId>
                    <version>${jacoco.version}</version>
                    <configuration>
                        <excludes>
                            <!-- AWS client wiring is exercised only against real endpoints. -->
                            <exclude>**/config/**</exclude>
                        </excludes>
                    </configuration>
                    <executions>
                        <execution>
                            <id>jacoco-unit-agent</id>
                            <goals>
                                <goal>prepare-agent</goal>
                            </goals>
                            <configuration>
                                <destFile>${project.build.directory}/jacoco-unit.exec</destFile>
                                <propertyName>jacocoUnitAgent</propertyName>
                            </configuration>
                        </execution>
                        <execution>
                            <id>jacoco-it-agent</id>
                            <goals>
                                <goal>prepare-agent-integration</goal>
                            </goals>
                            <configuration>
                                <destFile>${project.build.directory}/jacoco-it.exec</destFile>
                                <propertyName>jacocoItAgent</propertyName>
                            </configuration>
                        </execution>
                        <execution>
                            <id>jacoco-merge</id>
                            <phase>post-integration-test</phase>
                            <goals>
                                <goal>merge</goal>
                            </goals>
                            <configuration>
                                <fileSets>
                                    <fileSet>
                                        <directory>${project.build.directory}</directory>
                                        <includes>
                                            <include>jacoco-unit.exec</include>
                                            <include>jacoco-it.exec</include>
                                        </includes>
                                    </fileSet>
                                </fileSets>
                                <destFile>${project.build.directory}/jacoco-merged.exec</destFile>
                            </configuration>
                        </execution>
                        <execution>
                            <id>jacoco-merged-report</id>
                            <phase>post-integration-test</phase>
                            <goals>
                                <goal>report</goal>
                            </goals>
                            <configuration>
                                <dataFile>${project.build.directory}/jacoco-merged.exec</dataFile>
                            </configuration>
                        </execution>
                        <execution>
                            <id>jacoco-check</id>
                            <goals>
                                <goal>check</goal>
                            </goals>
                            <configuration>
                                <dataFile>${project.build.directory}/jacoco-merged.exec</dataFile>
                                <haltOnFailure>${jacoco.check.haltOnFailure}</haltOnFailure>
                                <rules>
                                    <rule>
                                        <element>BUNDLE</element>
                                        <limits>
                                            <limit>
                                                <counter>LINE</counter>
                                                <value>COVEREDRATIO</value>
                                                <minimum>0.80</minimum>
                                            </limit>
                                        </limits>
                                    </rule>
                                </rules>
                            </configuration>
                        </execution>
                    </executions>
                </plugin>
            </plugins>
        </pluginManagement>
        <plugins>
            <!-- Spotless enforces consistent Java formatting across every module.
                 Fix locally with `./mvnw spotless:apply`; `spotless:check` runs at the verify phase
                 (and so gates CI, which runs `mvn verify`). -->
            <plugin>
                <groupId>com.diffplug.spotless</groupId>
                <artifactId>spotless-maven-plugin</artifactId>
                <version>3.7.0</version>
                <configuration>
                    <java>
                        <removeUnusedImports/>
                        <palantirJavaFormat/>
                    </java>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>check</goal>
                        </goals>
                        <phase>verify</phase>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>


    <profiles>
        <!-- Opt-in: `./mvnw verify -Pintegration-tests` runs LocalStack-backed *IT tests.
             Requires a running Docker daemon. Plain `mvn verify` is unaffected. -->
        <profile>
            <id>integration-tests</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-failsafe-plugin</artifactId>
                        <executions>
                            <execution>
                                <goals>
                                    <goal>integration-test</goal>
                                    <goal>verify</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

</project>
